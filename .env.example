# Example environment variables for local development and Render.
# Copy to .env for local dev or set these in Render environment settings.

# Database (Render provides DATABASE_URL for managed DBs)
DATABASE_URL=
# or use individual vars
DB_HOST=
DB_PORT=
DB_NAME=
DB_USER=
DB_PASSWORD=

# App secrets
JWT_SECRET=replace-with-a-random-secret

# OpenAI (optional)
OPENAI_API_KEY=

# Comma-separated list of allowed CORS origins for the backend
ALLOWED_ORIGINS=https://mechanic-ai-ui.onrender.com
